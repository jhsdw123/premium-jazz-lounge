# =============================================================================
# Premium Jazz Lounge — 환경 변수 템플릿
# 사용법: 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요.
# .env.local 은 .gitignore 에 의해 커밋되지 않습니다.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...your-service-role-key...

# Storage bucket (Supabase Dashboard → Storage 에서 생성 필요)
SUPABASE_STORAGE_BUCKET=pjl-jazz-tracks

# --- LLM (Phase 3 에서 사용) -------------------------------------------------
# Gemini Pro: 제목 생성 / 번역 메인 엔진
GEMINI_API_KEY=

# OpenAI: 폴백 (선택)
OPENAI_API_KEY=

# --- 서버 --------------------------------------------------------------------
PORT=4001

# --- YouTube OAuth (Phase 5-A) -----------------------------------------------
# Google Cloud Console (PJL-BOT 프로젝트) → APIs & Services → Credentials →
#   "OAuth 2.0 Client IDs" 의 client_id / client_secret 을 그대로 붙여넣기.
# Authorized redirect URI 에는 정확히 아래 YOUTUBE_REDIRECT_URI 값과 같은 URL 등록되어야 함.
# YOUTUBE_TOKEN_PATH 는 access_token + refresh_token 저장 경로 (gitignore: secrets/).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4001/auth/youtube/callback
YOUTUBE_TOKEN_PATH=secrets/youtube-token.json
